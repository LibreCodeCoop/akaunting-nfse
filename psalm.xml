<psalm
    errorLevel="3"
    phpVersion="8.2"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
>
    <projectFiles>
        <directory name="Http" />
        <directory name="Models" />
        <directory name="Providers" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>

    <stubs>
        <file name="stubs/framework.php" />
    </stubs>

    <issueHandlers>
        <PossiblyUnusedMethod errorLevel="info" />
        <PossiblyUnusedParam errorLevel="info" />
        <PossiblyUnusedProperty errorLevel="info" />
        <UndefinedClass errorLevel="info" />
        <UndefinedFunction errorLevel="info" />
        <UndefinedMethod errorLevel="info" />
        <UnusedClass errorLevel="info" />
    </issueHandlers>
</psalm>
